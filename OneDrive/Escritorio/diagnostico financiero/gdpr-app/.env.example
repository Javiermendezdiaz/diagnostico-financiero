# Backend Configuration
PORT=3001
NODE_ENV=development

# JWT Configuration (CHANGE THIS IN PRODUCTION)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars
JWT_EXPIRATION=7d

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001

# Database Configuration (PostgreSQL)
# Required format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gdpr_requests

# Database Connection Pooling
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# GDPR Compliance
GDPR_REQUEST_VALIDITY_DAYS=30
GDPR_DATA_RETENTION_DAYS=90
GDPR_LEGAL_NOTICE_ES=true

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIR=./logs

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Email Configuration (SMTP for request notifications)
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASSWORD=
SMTP_FROM=GDPR Requests <noreply@example.com>
SMTP_TIMEOUT=10000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
ENCRYPTION_ENABLED=false
ENCRYPTION_ALGORITHM=aes-256-gcm
ENCRYPTION_KEY=

# Monitoring & Alerts
SENTRY_DSN=
SLACK_WEBHOOK_URL=
ALERT_EMAIL=admin@example.com

# Application Settings
APP_NAME=GDPR Data Request
APP_VERSION=1.0.0
APP_URL=http://localhost:3000
